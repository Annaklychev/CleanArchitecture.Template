@page "/Register"

<h3>@(_textTable?.PagesRegisterTitle ?? "Register")</h3>

<EditForm Model="registerModel" OnValidSubmit="HandleRegister">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <label>@(_textTable?.PagesRegisterEmailLabel ?? "Email")</label>
        <InputText @bind-Value="registerModel.Email" />
    </div>
    <div>
        <label>@(_textTable?.PagesRegisterPasswordLabel ?? "Password")</label>
        <InputText @bind-Value="registerModel.Password" type="password" />
    </div>
    <div>
        <label>@(_textTable?.PagesRegisterConfirmPasswordLabel ?? "Confirm Password")</label>
        <InputText @bind-Value="registerModel.ConfirmPassword" type="password" />
    </div>

    <button type="submit">@(_textTable?.PagesRegisterSubmitButton ?? "Register")</button>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <p style="color:red">@errorMessage</p>
    }
</EditForm>

