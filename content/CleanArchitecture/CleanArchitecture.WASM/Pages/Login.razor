@page "/login"

<h3>@(_textTable?.PagesLoginTitle ?? "Login")</h3>

<EditForm Model="loginModel" OnValidSubmit="HandleLogin">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <label>@(_textTable?.PagesLoginEmailLabel ?? "Email")</label>
        <InputText @bind-Value="loginModel.Email" />
    </div>
    <div>
        <label>@(_textTable?.PagesLoginPasswordLabel ?? "Password")</label>
        <InputText @bind-Value="loginModel.Password" type="password" />
    </div>

    <button type="submit">@(_textTable?.PagesLoginSubmitButton ?? "Login")</button>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <p style="color:red">@errorMessage</p>
    }
</EditForm>

