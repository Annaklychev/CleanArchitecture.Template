@using Toolbelt.Blazor.I18nText
@inject Toolbelt.Blazor.I18nText.I18nText I18n

<div class="language-switcher">
    <button class="lang-btn @(currentLang == "en" ? "active" : "")" 
            @onclick="@(() => SwitchLanguage("en"))">
        EN
    </button>
    <button class="lang-btn @(currentLang == "ru" ? "active" : "")" 
            @onclick="@(() => SwitchLanguage("ru"))">
        RU
    </button>
</div>

@code {
    private string currentLang = "en";

    protected override async Task OnInitializedAsync()
    {
        currentLang = await I18n.GetCurrentLanguageAsync();
    }

    private async Task SwitchLanguage(string lang)
    {
        currentLang = lang;
        await I18n.SetCurrentLanguageAsync(lang);
        StateHasChanged();
    }
}
